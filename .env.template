# ServiceNow Connection
# Your ServiceNow production instance URL (no trailing slash)
SERVICENOW_INSTANCE=https://sweetgreen.service-now.com

# OAuth client registered in ServiceNow Application Registry
# Must support Authorization Code + PKCE grant type
SERVICENOW_OAUTH_CLIENT_ID=
SERVICENOW_OAUTH_CLIENT_SECRET=

# MCP Server Configuration
# Public URL where this server is reachable (used for OAuth callbacks)
MCP_SERVER_BASE_URL=https://mcp-servicenow.internal.sweetgreen.com
MCP_SERVER_PORT=8080

# Tool Profile
# tickets  = incidents + requests only (default, for most employees)
# itsm     = tickets + changes + SLAs (for IT staff)
# full     = all tools including CMDB and knowledge base
# custom   = use SERVICENOW_ENABLED_GROUPS below
SERVICENOW_TOOL_PROFILE=tickets

# Custom Tool Groups (only used when SERVICENOW_TOOL_PROFILE=custom)
# Comma-separated list: auth,incidents,changes,requests,universal_requests,
#   knowledge,private_tasks,slas,cmdb,intelligent_query
# SERVICENOW_ENABLED_GROUPS=incidents,requests,intelligent_query

# Logging
LOG_LEVEL=INFO
